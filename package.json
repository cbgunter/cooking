{
  "name": "cooking",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*",
    "infra"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/ai && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
